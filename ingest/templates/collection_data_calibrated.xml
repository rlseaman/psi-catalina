    <Identification_Area>
        <logical_identifier>urn:nasa:pds:gbo.ast.catalina.survey:data_calibrated</logical_identifier>
        <version_id>{{ major }}.{{ minor }}</version_id>
        <title>Catalina Sky Survey Bundle: Calibrated Data Collection</title>
        <information_model_version>1.16.0.0</information_model_version>
        <product_class>Product_Collection</product_class>   
        <Citation_Information>
            <author_list>Seaman, R., Christensen, E., Gibbs, A., and Shelly, F.</author_list>
            <publication_year>{{ year }}</publication_year>
            <description>
                Calibrated Data files for Catalina Sky Survey
            </description>
        </Citation_Information>
        <Modification_History>
            {% for h in modification_history %}
            <Modification_Detail>
              <modification_date>{{ h.modification_date }}</modification_date>
              <version_id>{{ h.version_id }}</version_id>
              <description>{{ h.description }}</description>
            </Modification_Detail>
            {% endfor %}
            <Modification_Detail>
              <modification_date>{{ latest_modification.modification_date }}</modification_date>
              <version_id>{{ latest_modification.version_id }}</version_id>
              <description>{{ latest_modification.description }}</description>
            </Modification_Detail>
        </Modification_History>
    </Identification_Area>
    
    <Context_Area>


