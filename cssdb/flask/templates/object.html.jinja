<html>
    <head>
        <link href='/static/style.css' rel='stylesheet'>
    </head>
    <body>
        <h1>Details for Object {{ objid }}</h1>

        {% if followups %}
        <h2>Followups</h2>
        <table>
            <tr>
                <th>Code</th>
                <th>Object</th>
                <th>RA</th>
                <th>Dec</th>
                <th>Magnitude</th>
                <th>Comment</th>
                <th>Field</th>
                <th>Observing Run</th>
                <th>Observatory</th>
                <th>Telescope</th>
                <th>Camera</th>
                <th>Operator</th>
            </tr>
            {% for followup in followups %}
            <tr>
                <td>{{ followup.followup_code }}</td>
                <td>{{ followup.followup_name }}</td>
                <td>{{ followup.ra }}</td>
                <td>{{ followup.declination }}</td>
                <td>{{ followup.magnitude }}</td>
                <td>{{ followup.comment }}</td>
                <td>
                        {% if followup.field_code %}
                        <a href='/field/{{ followup.field_code }}'>
                            {{ followup.field_code }}
                        </a>
                        {% endif %}
                </td>                
                <td><a href='/night/{{ followup.night_id }}'>{{ followup.obsdate }}</a></td>
                <td>{{ followup.observatory }}</td>
                <td>{{ followup.telescope }}</td>
                <td>{{ followup.camera }}</td>
                <td>{{ followup.operator }}</td>
            </tr>
            {% endfor %}
        </table>
        {% endif %}

        {% if userfields %}
        <h2>User-Specified Fields</h2>
        <table>
            <tr>
                <th>Code</th>
                <th>Name</th>
                <th>RA</th>
                <th>Dec</th>
                <th>Magnitude</th>
                <th>Comment</th>
                <th>Field</th>
                <th>Observing Run</th>
                <th>Observatory</th>
                <th>Telescope</th>
                <th>Camera</th>
                <th>Operator</th>
            </tr>
            {% for userfield in userfields %}
            <tr>
                <td>{{ userfield.userfield_code }}</td>
                <td>{{ userfield.userfield_name }}</td>
                <td>{{ userfield.ra }}</td>
                <td>{{ userfield.declination }}</td>
                <td>{{ userfield.magnitude }}</td>
                <td>{{ userfield.comment}}</td>
                <td>
                        {% if userfield.field_code %}
                        <a href='/field/{{ userfield.field_code }}'>
                            {{ userfield.field_code }}
                        </a>
                        {% endif %}
                </td>                
                <td><a href='/night/{{ userfield.night_id }}'>{{ userfield.obsdate }}</a></td>
                <td>{{ userfield.observatory }}</td>
                <td>{{ userfield.telescope }}</td>
                <td>{{ userfield.camera }}</td>
                <td>{{ userfield.operator }}</td>
            </tr>
            {% endfor %}
        </table>
        {% endif %}

        {% if neos %}
        <h2>NEOs</h2>
        <table>
            <tr>
                <th>Object</th>
                <th>Date</th>
                <th>RA</th>
                <th>Dec</th>
                <th>Magnitude</th>
                <th>Observing Run</th>
                <th>Observatory</th>
                <th>Telescope</th>
                <th>Camera</th>
                <th>Operator</th>
            </tr>
            {% for neo in neos %}
            <tr>
                <td>{{ neo.neo_code }}</td>
                <td>{{ neo.obstime }}</td>
                <td>{{ neo.ra }}</td>
                <td>{{ neo.declination }}</td>
                <td>{{ neo.magnitude }}</td>
                <td><a href='/night/{{ neo.night_id }}'>{{ neo.obsdate }}</a></td>
                <td>{{ neo.observatory }}</td>
                <td>{{ neo.telescope }}</td>
                <td>{{ neo.camera }}</td>
                <td>{{ neo.operator }}</td>
            </tr>
            {% endfor %}
        </table>    
        {% endif %}    

        {% if astrometries %}
        <h2>Astrometry</h2>
        <table>
            <tr>
                <th>Object</th>
                <th>Date</th>
                <th>RA</th>
                <th>Dec</th>
                <th>Magnitude</th>
                <th>Observing Run</th>
                <th>Observatory</th>
                <th>Telescope</th>
                <th>Camera</th>
                <th>Operator</th>
            </tr>
            {% for astr in astrometries %}
            <tr>
                <td>{{ astr.astr_code }}</td>
                <td>{{ astr.obstime }}</td>
                <td>{{ astr.ra }}</td>
                <td>{{ astr.declination }}</td>
                <td>{{ astr.magnitude }}</td>
                <td><a href='/night/{{ astr.night_id }}'>{{ astr.obsdate }}</a></td>
                <td>{{ astr.observatory }}</td>
                <td>{{ astr.telescope }}</td>
                <td>{{ astr.camera }}</td>
                <td>{{ astr.operator }}</td>
            </tr>
            {% endfor %}
        </table>        
        {% endif %}

    </body>

</html>