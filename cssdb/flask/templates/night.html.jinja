<html>
    <head>
        <link href='/static/style.css' rel='stylesheet'>
    </head>
    <body>
        <h1>Details for Night {{ night.obsdate }}</h1>
        <h2>Observatory: {{ night.observatory }}</h2>
        <h2>Telescope: {{ night.telescope }}</h2>
        <h2>Camera: {{ night.camera }}</h2>
        <h2>Operator: {{ night.operator }}</h2>

        {% if surveyfields %}
        <a href="#surveyfields">Survey Fields</a>
        {% endif %}
        {% if followups %}
        <a href="#followups">Followups</a>
        {% endif %}
        {% if userfields %}
        <a href="#userfields">User Fields</a>
        {% endif %}
        {% if neos %}
        <a href="#neos">NEOs</a>
        {% endif %}
        {% if observations %}
        <a href="#observations">Observations</a>
        {% endif %}


        {% if surveyfields %}
        <a id="surveyfields"></a>
        <h2>Survey Plan ({{ surveyfields|length() }})</h2>
        <img src='/img/survey/{{ night.night_id }}' alt='building graph...'>
        <p><a onclick='tableSurveyFields.style.display=""'>Show</a></p>
        <table id='tableSurveyFields' style='display:none'>
            <tr>
                <th>Code</th>
                <th>MJD</th>
                <th>RA</th>
                <th>Dec</th>
            </tr>
            {% for surveyfield in surveyfields %}
            <tr>
                <td><a href='/field/{{ surveyfield.surveyfield_code }}'>{{ surveyfield.surveyfield_code }}</a></td>
                <td>{{ surveyfield.mjd }}</td>
                <td>{{ surveyfield.ra }}</td>
                <td>{{ surveyfield.declination }}</td>
            </tr>
            {% endfor %}
        </table>        
        {% endif %}

        {% if followups %}
        <a id="followups"></a>
        <h2>Followups ({{ followups|length() }})</h2>
        <img src='/img/followups/{{ night.night_id }}' alt='building graph...'>
        <p><a onclick='tableFollowups.style.display=""'>Show</a></p>
        <table id='tableFollowups' style='display:none'>
            <tr>
                <th>Code</th>
                <th>Name</th>
                <th>RA</th>
                <th>Dec</th>
                <th>Magnitude</th>
                <th>Comment</th>
                <th>Field</th>
            </tr>
            {% for followup in followups %}
            <tr>
                <td>{{ followup.followup_code }}</td>
                <td><a href='/object/{{ followup.followup_name }}'>{{ followup.followup_name }}</a></td>
                <td>{{ followup.ra }}</td>
                <td>{{ followup.declination }}</td>
                <td>{{ followup.magnitude }}</td>
                <td>{{ followup.comment }}</td>
                <td>
                    {% if followup.field_code %}
                    <a href='/field/{{ followup.field_code }}'>
                        {{ followup.field_code }}
                    </a>
                    {% endif %}
                </td>
            </tr>
            {% endfor %}
        </table>
        {% endif %}

        {% if userfields %}
        <a id='userfields'></a>
        <h2>User-Specified Fields ({{ userfields|length() }})</h2>
        <img src='/img/userfields/{{ night.night_id }}' alt='building graph...'>
        <p><a onclick='tableUserFields.style.display=""'>Show</a></p>
        <table id='tableUserFields' style='display:none'>
            <tr>
                <th>Code</th>
                <th>Name</th>
                <th>RA</th>
                <th>Dec</th>
                <th>Magnitude</th>
                <th>Comment</th>
                <th>Field</th>
            </tr>
            {% for userfield in userfields %}
            <tr>
                <td>{{ userfield.userfield_code }}</td>
                <td><a href='/object/{{ userfield.userfield_name }}'>{{ userfield.userfield_name }}</a></td>
                <td>{{ userfield.ra }}</td>
                <td>{{ userfield.declination }}</td>
                <td>{{ userfield.magnitude }}</td>
                <td>{{ userfield.comment}}</td>
                <td>
                    {% if userfield.field_code %}
                    <a href='/field/{{ userfield.field_code }}'>
                        {{ userfield.field_code }}
                    </a>
                    {% endif %}
                </td>
        </tr>
            {% endfor %}
        </table>
        {% endif %}

        {% if neos %}
        <a id='neos'></a>
        <h2>NEOs ({{ neos|length() }})</h2>
        <img src='/img/neos/{{ night.night_id }}' alt='building graph...'>
        <p><a onclick='tableNEOs.style.display=""'>Show</a></p>
        <table id='tableNEOs' style='display:none'>
            <tr>
                <th>Object</th>
                <th>Date</th>
                <th>RA</th>
                <th>Dec</th>
                <th>Magnitude</th>
            </tr>
            {% for neo in neos %}
            <tr>
                <td><a href='/object/{{ neo.neo_code }}'>{{ neo.neo_code }}</a></td>
                <td>{{ neo.obstime }}</td>
                <td>{{ neo.ra }}</td>
                <td>{{ neo.declination }}</td>
                <td>{{ neo.magnitude }}</td>
            </tr>
            {% endfor %}
        </table>   
        {% endif %}     


        {% if observations %}
        <a id='observations'></a>
        <h2>Observations ({{ observations|length() }})</h2>
        <p><a onclick='tableObservations.style.display=""'>Show</a></p>
        <table id='tableObservations' style='display:none'>
            <tr>
                <th>File</th>
            </tr>
            {% for observation in observations %}
            <tr>
                <td>{{ observation.obsfile }}</td>
            </tr>
            {% endfor %}
        </table>
        {% endif %}

    
    </body>

</html>