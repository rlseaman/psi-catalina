          <lid_reference>urn:nasa:pds:context:instrument:mount_lemmon.1m54.10kccd</lid_reference>
          <reference_type>is_instrument</reference_type>
        </Internal_Reference>
      </Observing_System_Component>
      <Observing_System_Component>
